{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "types": ["bun"],

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Monorepo: resolve workspace packages for `tsc --noEmit`
    // (paths without baseUrl resolve relative to this tsconfig)
    "paths": {
      "@ryuzi/protocol": ["./packages/protocol/src/index.ts"],
      "@ryuzi/core": ["./packages/core/src/index.ts"]
    },

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  "include": ["apps", "packages"],
  // apps/cockpit and packages/ui are DOM/React workspaces with their own tsconfig
  // (DOM lib + `@/` path alias). They are type-checked separately by the `typecheck`
  // script; excluded here so this Bun-side config (no DOM lib) does not false-fail them.
  "exclude": ["apps/cockpit", "packages/ui", "**/node_modules", "**/dist"]
}
